# 活动 ID
BW_PROJECT_ID=1001653

# 目标日期索引：0=7月10日 / 1=7月11日 / 2=7月12日
BW_DAY_FLAG=0

# 请求限制弹窗检查/点击间隔（毫秒）
BW_CLICK_LIMIT_INTERVAL_MS=1000

# 查票接口轮询间隔（毫秒）
BW_CHECK_TICKET_INTERVAL_MS=1000

# Chrome 专用持久化 profile 目录
BW_CHROME_PROFILE=E:/code/bw_tickets/.chrome-profile

# Edge 专用持久化 profile 目录
BW_EDGE_PROFILE=E:/code/bw_tickets/.edge-profile

# 浏览器可执行文件路径（留空则自动检测：优先 Chrome，回退 Edge）
BW_BROWSER_EXECUTABLE=

# headless 模式：留空或 0 为可视化，1 为无头
BW_HEADLESS=

# 详情页开始操作时间（留空则立即执行；格式 HH:mm:ss 或 HH:mm:ss.S，精确到 0.1 秒）
BW_DETAIL_START_TIME=12:00:00.0

# 详情页点击购买后等待选票层的超时时间（毫秒）
BW_DETAIL_RELOAD_WAIT_MS=10000

# 确认订单页未检测到有票时随机提交概率（0~1）
BW_SUBMIT_WITHOUT_TICKET_CHANCE=0.26

# 进入支付页后打开的提醒 URL
BW_SUCCESS_URL=https://www.bilibili.com/video/BV1sa4y1H7ek

# 自定义 User-Agent（留空则使用浏览器默认）
# 示例：Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36
BW_USER_AGENT=

# 自定义 Accept-Language（留空则使用浏览器默认）
# 示例：zh-CN,zh;q=0.9,en;q=0.8
BW_ACCEPT_LANGUAGE=

# 隐藏 navigator.webdriver 等自动化特征：1 启用，留空关闭
BW_HIDE_WEBDRIVER=
